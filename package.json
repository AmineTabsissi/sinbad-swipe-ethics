{
  "name": "sinbad-swipe-ethics",
  "description": "Arabian Nights anthology web app — Sinbad, Aladdin, Ebony Horse (Vite + React + TypeScript).",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:docs": "tsc -b && vite build --outDir docs --emptyOutDir",
    "deploy:docs": "npm run build:docs",
    "preview:docs": "npm run build:docs && vite preview --outDir docs --base /sinbad-swipe-ethics/",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
